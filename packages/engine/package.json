{
  "name": "@stay-focused/engine",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc -p tsconfig.evals.json",
    "eval": "node dist/evals/run-evals.js",
    "eval:stage0": "node dist/evals/stage0-normalization.eval.js",
    "eval:stage1": "node dist/evals/stage1-outline.eval.js",
    "eval:stage2": "node dist/evals/stage2-plan.eval.js",
    "eval:stage3": "node dist/evals/stage3-generate.eval.js",
    "eval:stage4": "node dist/evals/stage4-verify.eval.js",
    "eval:stage5a": "node dist/evals/stage5a-grounding.eval.js",
    "eval:stage5": "node dist/evals/stage5-retry.eval.js",
    "eval:stage6": "node dist/evals/stage6-assemble.eval.js",
    "eval:fidelity": "node dist/evals/source-token-fidelity.eval.js",
    "eval:pipeline": "node dist/evals/pipeline.eval.js",
    "live-run": "tsc -p tsconfig.live-run.json && node dist-live/scripts/live-run.js",
    "diagnose:stage012": "tsc -p tsconfig.live-run.json && node dist-live/scripts/diagnose-stage012.js",
    "validate:api-reviewer": "tsx scripts/api-reviewer-functional-test.ts",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.evals.json && tsc --noEmit -p tsconfig.live-run.json",
    "clean": "rimraf dist dist-live"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "dotenv": "~16.4.5",
    "openai": "^6.42.0"
  }
}
