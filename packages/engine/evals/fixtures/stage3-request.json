{
  "cases": [
    {
      "name": "concept request uses concept schema",
      "schemaKind": "concept-card",
      "expectSchemaName": "ConceptCard"
    },
    {
      "name": "process request uses process schema",
      "schemaKind": "process-step",
      "expectSchemaName": "ProcessStep"
    },
    {
      "name": "example request uses example schema",
      "schemaKind": "example-card",
      "expectSchemaName": "ExampleCard"
    },
    {
      "name": "claim request uses claim schema",
      "schemaKind": "claim-card",
      "expectSchemaName": "ClaimCard"
    },
    {
      "name": "provider receives default model",
      "schemaKind": "concept-card",
      "expectModel": "gpt-4o"
    },
    {
      "name": "provider receives custom model and temperature",
      "schemaKind": "concept-card",
      "model": "test-model",
      "temperature": 0.25,
      "expectModel": "test-model",
      "expectTemperature": 0.25
    },
    {
      "name": "prompt contains only planned passage",
      "schemaKind": "concept-card",
      "expectPromptContains": [
        "Included source alpha.",
        "Included source beta.",
        "Populate sourceCore.explanation and sourceCore.keyPoints from this card's passage alone.",
        "Put optional examples, outside knowledge, and clarifying context only in enrichment."
      ],
      "expectPromptExcludes": ["Excluded unrelated omega.", "Stay Focused V2 engine"],
      "expectPromptOrder": ["Included source alpha.", "Included source beta."]
    },
    {
      "name": "provider metadata includes plan and section context",
      "schemaKind": "claim-card",
      "metadata": { "evaluationCase": "metadata-check" },
      "expectMetadata": {
        "evaluationCase": "metadata-check",
        "plannedSectionId": "planned-claim-card",
        "planId": "stage3-plan",
        "schemaKind": "claim-card",
        "sourceId": "stage3-source"
      }
    },
    {
      "name": "prompt includes learning goal and output requirements",
      "schemaKind": "process-step",
      "expectPromptContains": [
        "Topic heading — Study Section",
        "Card shape — process-step",
        "Learning goal:",
        "Do not include project, repository, internal architecture, pipeline, engine, or Stay Focused references in any output field.",
        "Return JSON conforming to the supplied object format."
      ]
    }
  ]
}
