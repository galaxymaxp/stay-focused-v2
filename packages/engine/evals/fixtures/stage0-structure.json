{
  "cases": [
    {
      "name": "bullet list",
      "input": { "text": "- Nucleus\n- Cytoplasm\n- Cell membrane" },
      "expect": {
        "blockKinds": ["list"],
        "blockCount": 1,
        "containsText": ["- Nucleus", "- Cell membrane"]
      }
    },
    {
      "name": "numbered list",
      "input": { "text": "1. Observe\n2. Record\n3. Compare" },
      "expect": {
        "blockKinds": ["list"],
        "blockCount": 1,
        "containsText": ["1. Observe", "3. Compare"]
      }
    },
    {
      "name": "quote block",
      "input": { "text": "> Evidence should support the claim.\n> Sources should be cited." },
      "expect": {
        "blockKinds": ["quote"],
        "blockCount": 1,
        "containsText": ["> Evidence", "> Sources"]
      }
    },
    {
      "name": "fenced code block",
      "input": { "text": "```ts\nconst focused = true;\n```" },
      "expect": {
        "blockKinds": ["code"],
        "blockCount": 1,
        "containsText": ["```ts", "const focused = true;"]
      }
    },
    {
      "name": "Markdown table",
      "input": { "text": "| Term | Meaning |\n| --- | --- |\n| Cell | Basic unit of life |" },
      "expect": {
        "blockKinds": ["table"],
        "blockCount": 1,
        "containsText": ["| Term | Meaning |", "Basic unit of life"]
      }
    },
    {
      "name": "flat OCR heading lines recover section blocks",
      "input": {
        "text": "Social Engineering\nPretexting uses a false story to gain trust.\nTailgating follows an authorized person into a restricted area.\nPhishing sends deceptive messages to collect private details.\nSmishing uses text messages for phishing.\nVishing uses phone calls for phishing.\nPassword Cracking\nBrute-force tries many possible passwords until one works.\nNetwork Sniffing captures traffic to inspect exposed data.\nImpact Reduction\nStrong password policies reduce easy guessing.\nTraining helps people recognize suspicious requests."
      },
      "expect": {
        "title": "Social Engineering",
        "blockKinds": [
          "heading",
          "paragraph",
          "heading",
          "paragraph",
          "heading",
          "paragraph"
        ],
        "blockCount": 6,
        "containsText": [
          "Social Engineering",
          "Pretexting",
          "Tailgating",
          "Phishing",
          "Smishing",
          "Vishing",
          "Password Cracking",
          "Brute-force",
          "Network Sniffing",
          "Impact Reduction"
        ],
        "deterministicIds": true
      }
    },
    {
      "name": "deterministic block order",
      "input": {
        "id": "ordered-source",
        "blocks": [
          { "kind": "paragraph", "text": "Third", "order": 30 },
          { "kind": "heading", "text": "First", "order": 10 },
          { "kind": "paragraph", "text": "Second", "order": 20 }
        ]
      },
      "expect": {
        "title": "First",
        "blockKinds": ["heading", "paragraph", "paragraph"],
        "blockTexts": ["First", "Second", "Third"],
        "blockOrders": [0, 1, 2],
        "deterministicIds": true
      }
    }
  ]
}
