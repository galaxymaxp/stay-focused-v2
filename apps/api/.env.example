NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Required application encryption secret for per-user Canvas credentials.
# Generated and owned by the Stay Focused deployment. Not provided by Canvas,
# the school, or the student. Must decode to exactly 32 bytes.
CANVAS_TOKEN_ENCRYPTION_KEY=

# Optional developer live Canvas validation only. The primary names used by
# the live-validation harness are CANVAS_BASE_URL and
# CANVAS_PERSONAL_ACCESS_TOKEN. Compatibility aliases below are accepted only
# by the validation harness.
CANVAS_BASE_URL=
CANVAS_PERSONAL_ACCESS_TOKEN=
CANVAS_ACCESS_TOKEN=
CANVAS_LIVE_BASE_URL=
CANVAS_LIVE_PERSONAL_ACCESS_TOKEN=
