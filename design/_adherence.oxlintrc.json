{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/glass/**",
              "components/schedule/**",
              "ui_kits/mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Hanken Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Hanken Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|dot|tone|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: count, dot, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|red|green|neutral)$/]",
        "message": "<Badge> tone must be one of 'accent' | 'red' | 'green' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|full|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, full, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padding|selected|accent|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padding, selected, accent, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|soft|iconLeft|children|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: tone, soft, iconLeft, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|accent|red|amber|green|blue)$/]",
        "message": "<Chip> tone must be one of 'neutral' | 'accent' | 'red' | 'amber' | 'green' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassFAB'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|key|ref|className|style|children)$/]",
        "message": "<GlassFAB> doesn't accept that prop. Declared props: icon, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassNavBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|leading|trailing|large|style|key|ref|className|style|children)$/]",
        "message": "<GlassNavBar> doesn't accept that prop. Declared props: title, subtitle, leading, trailing, large, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassTabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|key|ref|className|style|children)$/]",
        "message": "<GlassTabItem> doesn't accept that prop. Declared props: id, label, icon."
      },
      {
        "selector": "JSXOpeningElement[name.name='NowHero'] > JSXAttribute > JSXIdentifier[name!=/^(?:kicker|title|course|courseTone|reason|timeLabel|timeLeft|progress|primaryLabel|onPrimary|secondaryLabel|onSecondary|startIcon|style|key|ref|className|style|children)$/]",
        "message": "<NowHero> doesn't accept that prop. Declared props: kicker, title, course, courseTone, reason, timeLabel, timeLeft, progress, primaryLabel, onPrimary, secondaryLabel, onSecondary, startIcon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NowHero'] > JSXAttribute[name.name='courseTone'] > Literal[value!=/^(?:accent|red|amber|green|blue|neutral)$/]",
        "message": "<NowHero> courseTone must be one of 'accent' | 'red' | 'amber' | 'green' | 'blue' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScheduleBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:time|endTime|title|course|tone|state|meta|trailing|last|key|ref|className|style|children)$/]",
        "message": "<ScheduleBlock> doesn't accept that prop. Declared props: time, endTime, title, course, tone, state, meta, trailing, last."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScheduleBlock'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|red|amber|green|blue|neutral)$/]",
        "message": "<ScheduleBlock> tone must be one of 'accent' | 'red' | 'amber' | 'green' | 'blue' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScheduleBlock'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:default|now|done)$/]",
        "message": "<ScheduleBlock> state must be one of 'default' | 'now' | 'done'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
